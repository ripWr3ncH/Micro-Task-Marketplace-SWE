    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task (Buyer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{buyerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design a landing page\",\n  \"description\": \"Need responsive page for product\",\n  \"budget\": 120.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
